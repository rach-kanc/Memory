{
  "name": "memact-memory",
  "private": true,
  "version": "0.0.0",
  "description": "Secure database storing user approved context and evidence.",
  "license": "BUSL-1.1",
  "type": "module",
  "main": "./src/engine.mjs",
  "exports": {
    ".": "./src/engine.mjs",
    "./competing-origins": "./src/competing-origins.mjs",
    "./claims": "./src/claims.mjs",
    "./core-schemas": "./src/core-schemas.mjs",
    "./evidence-links": "./src/evidence-links.mjs",
    "./graph-snapshots": "./src/graph-snapshots.mjs",
    "./influence-categories": "./src/influence-categories.mjs",
    "./influence-paths": "./src/influence-paths.mjs",
    "./negative-evidence": "./src/negative-evidence.mjs",
    "./scoring": "./src/scoring.mjs",
    "./source-metadata": "./src/source-metadata.mjs",
    "./field-encryption": "./src/field-encryption.mjs",
    "./postgres-statements": "./src/postgres-statements.mjs",
    "./memory-schemas": "./src/memory-schemas.mjs",
    "./backup-restore": "./src/backup-restore.mjs",
    "./semantic-matching": "./src/semantic-matching.mjs",
    "./task-context-packet": "./src/task-context-packet.mjs",
    "./cap-packet": "./src/cap-packet.mjs",
    "./context-worker": "./src/context-worker.mjs",
    "./temporal-paths": "./src/temporal-paths.mjs",
    "./cli": "./src/cli.mjs",
    "./memory-stats": "./src/memory-stats.mjs",
    "./stats-server": "./src/stats-server.mjs",
    "./read-write-executor": "./src/read-write-executor.mjs"
  },
  "keywords": [
    "memact",
    "memory",
    "context",
    "schema-packets",
    "meaning-packets",
    "provenance",
    "rag",
    "crud"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Memact/Memory.git"
  },
  "homepage": "https://github.com/Memact/Memory",
  "engines": {
    "node": ">=24"
  },
  "bin": {
    "memact-memory": "./src/cli.mjs",
    "memact-memory-backup": "./scripts/memory-backup.mjs"
  },
  "scripts": {
    "benchmarks": "node ./scripts/benchmarks.mjs",
    "check": "node ./scripts/check.mjs",
    "test": "node --test test/*.test.mjs",
    "memory": "node ./src/cli.mjs",
    "backup": "node ./scripts/memory-backup.mjs",
    "sample": "node ./src/cli.mjs --inference examples/sample-inference-output.json --schema examples/sample-schema-output.json --format report",
    "sample:json": "node ./src/cli.mjs --inference examples/sample-inference-output.json --schema examples/sample-schema-output.json --format json",
    "sample:graph": "node ./src/cli.mjs --inference examples/sample-inference-output.json --schema examples/sample-schema-output.json --format graph",
    "sample:mermaid": "node ./src/cli.mjs --inference examples/sample-inference-output.json --schema examples/sample-schema-output.json --format mermaid"
  },
  "dependencies": {
    "pg": "^8.22.0"
  }
}
